{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.3-codex",
  "small_model": "llama.cpp/qwen3.5:35b_a3b",
  "default_agent": "assistant",
  "agent": {
    "plan": {
      "model": "openai/gpt-5.3-codex",
      "variant": "high"
    },
    "build": {
      // "model": "llama.cpp/qwen3.5:35b_a3b"
      "model": "openai/gpt-5.3-codex",
      "variant": "high"
    }
    // "general": {
    //   "model": "llama.cpp/qwen3.5:35b_a3b"
    // },
    // "explore": {
    //   "model": "llama.cpp/qwen3.5:9b"
    // }
  },
  "provider": {
    "openai": {
      "models": {
        "gpt-5.3-codex": {
          "options": {
            "reasoningEffort": "high"
          },
          "variants": {
            "low": {
              "reasoningEffort": "low"
            },
            "medium": {
              "reasoningEffort": "medium"
            },
            "high": {
              "reasoningEffort": "high"
            }
          }
        }
      }
    },
    "llama.cpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama-server (local)",
      "options": {
        "baseURL": "http://127.0.0.1:8080/v1"
      },
      "models": {
        "qwen3.5:9b": {
          "name": "Qwen3.5:9B",
          "limit": {
            "context": 45000,
            "output": 8000
          }
        },
        "qwen3.5:35b_a3b": {
          "name": "Qwen3.5:35B_A3B",
          "limit": {
            "context": 150016,
            "output": 16000
          }
        }
      }
    }
  }
}
